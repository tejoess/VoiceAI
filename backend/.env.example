# ──────────────────────────────────────────────────────────────
#  Voice AI Platform — backend environment
#  Copy to `.env` and fill in. Keys are loaded lazily; the app
#  boots without them but realtime voice features need them.
# ──────────────────────────────────────────────────────────────

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
# Comma-separated origins allowed by CORS (frontend dev server)
CORS_ORIGINS=http://localhost:3000

# Postgres (async — driver is asyncpg)
DATABASE_URL=postgresql+asyncpg://vai:vai@localhost:5432/vai

# Redis
REDIS_URL=redis://localhost:6379/0

# ── Voice infrastructure: LiveKit ─────────────────────────────
# Needed to issue browser tokens and run the agent worker.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Speech to Text: Deepgram ──────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# ── LLM: OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=https://api.openai.com/v1

# ── TTS (English): Cartesia ───────────────────────────────────
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-2
CARTESIA_VERSION=2024-11-13

# ── TTS (Indian languages): Sarvam AI ─────────────────────────
SARVAM_API_KEY=
SARVAM_MODEL=bulbul:v3

# Realtime audio format (shared across providers)
AUDIO_SAMPLE_RATE=24000
